#!/bin/bash
# zfw engine v2 — applies the daemon-compiled ruleset.
#
# In v0.2 the rule logic lives in the zfwd daemon: it compiles rules.json into
# compiled.sh. This engine is the privileged executor — it runs that script
# and owns the dead-man / revert safety machinery.
#
# Usage:  zfw {apply [--safe] | commit | revert | status}
set -u

# Pin a deterministic PATH: the dead-man auto-revert runs as a systemd-run
# transient unit whose environment may carry only a minimal PATH (ZFW-S7).
export PATH="/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPILED="${ZFW_COMPILED:-$SELF_DIR/compiled.sh}"
# B4 (v1.1): atomic-apply variant. The daemon writes compiled.restore.sh
# next to compiled.sh on every recompile. ZFW_APPLY_MODE=restore makes
# apply/commit use it (chains swapped via iptables-restore, pre-validated
# with --test, atomic per table). Default "bash" keeps the proven
# line-by-line path. Selection happens in pick_compiled below.
COMPILED_RESTORE="${ZFW_COMPILED_RESTORE:-$SELF_DIR/compiled.restore.sh}"
APPLY_MODE="${ZFW_APPLY_MODE:-bash}"
DEADMAN="zfw-deadman"
# Boot-persistence unit installed by `commit` and removed by `revert`. The
# unit replays the committed compiled.sh at boot after docker.service is up
# (so DOCKER-USER exists before we add rules to it).
PERSIST_UNIT="/etc/systemd/system/zfw.service"

IPT="$(command -v iptables-legacy 2>/dev/null || command -v iptables)"
IPT6="$(command -v ip6tables-legacy 2>/dev/null || command -v ip6tables 2>/dev/null || true)"

log(){ echo "[zfw] $*"; }

# pick_compiled echoes the path of the script to run for the active
# apply mode. restore mode falls back to the bash script (with a warning)
# if the daemon has not written compiled.restore.sh yet, so an
# out-of-order upgrade never leaves apply with nothing to run.
pick_compiled(){
  if [ "$APPLY_MODE" = "restore" ]; then
    if [ -r "$COMPILED_RESTORE" ]; then
      echo "$COMPILED_RESTORE"; return 0
    fi
    echo "[zfw] WARN: ZFW_APPLY_MODE=restore but $COMPILED_RESTORE missing — falling back to bash path" >&2
  fi
  echo "$COMPILED"
}

# apply_or_die runs a command and aborts the engine if it fails. Used to
# wrap the commit-side chain (write_persist_unit + daemon-reload +
# systemctl enable) so a silent failure in any one step no longer leaves
# the operator believing boot-persistence is active when it isn't.
# CQ-10 (v1.0.2). Each step is run via "$@" so quoted arguments survive.
apply_or_die(){
  "$@" || { echo "[zfw] ERROR: $* failed" >&2; exit 1; }
}

# secure_file refuses a file that is not root-owned or is group/world-writable
# before it is executed as root (ZFW-S8).
secure_file(){
  local f="$1" u m
  read -r u m < <(stat -c '%U %a' "$f" 2>/dev/null) || true
  if [ -z "${u:-}" ]; then
    echo "[zfw] ERROR: cannot stat $f — refusing" >&2
    return 1
  fi
  if [ "$u" != "root" ]; then
    echo "[zfw] ERROR: $f not root-owned (owner=$u) — refusing" >&2
    return 1
  fi
  case "${m:-}" in
    *[2367][0-7] | *[2367])
      echo "[zfw] ERROR: $f is group/world-writable (mode=$m) — refusing" >&2
      return 1
      ;;
  esac
  return 0
}

revert(){
  $IPT -D INPUT -j ZFW-IN 2>/dev/null || true
  $IPT -F ZFW-IN 2>/dev/null || true
  $IPT -X ZFW-IN 2>/dev/null || true
  if $IPT -L DOCKER-USER -n >/dev/null 2>&1; then
    $IPT -F DOCKER-USER 2>/dev/null || true
    $IPT -A DOCKER-USER -j RETURN 2>/dev/null || true   # restore docker stock
  fi
  # Outbound chains (v0.5.6). Detach + flush + delete in the same
  # belt-and-braces pattern: each step is best-effort because the
  # chain may not exist on hosts where no outbound rules were ever
  # applied.
  $IPT -D OUTPUT -j ZFW-OUT 2>/dev/null || true
  $IPT -F ZFW-OUT 2>/dev/null || true
  $IPT -X ZFW-OUT 2>/dev/null || true
  $IPT -D FORWARD -j ZFW-FWD-OUT 2>/dev/null || true
  $IPT -F ZFW-FWD-OUT 2>/dev/null || true
  $IPT -X ZFW-FWD-OUT 2>/dev/null || true
  if [ -n "$IPT6" ]; then
    $IPT6 -D INPUT -j ZFW-IN6 2>/dev/null || true
    $IPT6 -F ZFW-IN6 2>/dev/null || true
    $IPT6 -X ZFW-IN6 2>/dev/null || true
    $IPT6 -D OUTPUT -j ZFW-OUT6 2>/dev/null || true
    $IPT6 -F ZFW-OUT6 2>/dev/null || true
    $IPT6 -X ZFW-OUT6 2>/dev/null || true
  fi
}

write_persist_unit(){
  # Atomic write: a concurrent reader (e.g. a stray `systemctl daemon-reload`)
  # must never see a half-written unit. Stage in .tmp on the same filesystem,
  # set the mode while still hidden, then rename — rename(2) is atomic within
  # one fs so the unit either exists in full or not at all.
  local tmp="${PERSIST_UNIT}.tmp"
  # Bake the active apply mode into the unit so a reboot replays exactly
  # what was committed — committing in restore mode must not silently
  # boot in bash mode (and vice versa).
  local env_line=""
  [ "$APPLY_MODE" = "restore" ] && env_line='Environment=ZFW_APPLY_MODE=restore'
  cat > "$tmp" <<UNIT
[Unit]
Description=ZFW Host Firewall — restore committed rules at boot
After=docker.service network-online.target
Wants=network-online.target
ConditionPathExists=/DATA/zfw/zfw
ConditionPathExists=/DATA/zfw/compiled.sh

[Service]
Type=oneshot
RemainAfterExit=yes
${env_line}
ExecStart=/DATA/zfw/zfw apply

[Install]
WantedBy=multi-user.target
UNIT
  chmod 0644 "$tmp"
  mv -f "$tmp" "$PERSIST_UNIT"
}

arm_deadman(){
  systemctl stop "${DEADMAN}.timer" 2>/dev/null || true
  systemctl reset-failed "${DEADMAN}.service" 2>/dev/null || true
  systemd-run --on-active=120 --unit="$DEADMAN" \
    /bin/bash "${BASH_SOURCE[0]}" _autorevert >/dev/null 2>&1
  log "DEADMAN ARMED — auto-revert in 120s unless you run:  zfw commit"
}

case "${1:-}" in
  apply)
    SCRIPT="$(pick_compiled)"
    [ -r "$SCRIPT" ] || { echo "[zfw] ERROR: compiled ruleset missing: $SCRIPT" >&2; exit 1; }
    secure_file "$SCRIPT" || exit 1
    [ "$APPLY_MODE" = "restore" ] && log "apply mode: restore (atomic, $SCRIPT)"
    safe=""
    [ "${2:-}" = "--safe" ] && safe=1
    # Arm the dead-man BEFORE touching iptables (ZFW-8): the compiled
    # script runs under `set -e`, so a bad rule aborts it (the restore
    # path additionally --tests each table first, but the dead-man stays
    # the active safety net at apply time). Arming it afterwards never
    # runs once the apply has already died.
    if [ -n "$safe" ]; then arm_deadman; fi
    if ! bash "$SCRIPT"; then
      echo "[zfw] ERROR: applying compiled ruleset failed — reverting partial state" >&2
      revert
      if [ -n "$safe" ]; then
        systemctl stop "${DEADMAN}.timer" 2>/dev/null || true
        systemctl reset-failed "${DEADMAN}.service" 2>/dev/null || true
      fi
      log "partial state reverted — firewall is OFF (stock ACCEPT); fix rules and re-apply"
      exit 1
    fi
    log "firewall applied"
    exit 0
    ;;
  commit)
    # Re-verify the compiled ruleset before promoting it to boot-persistence.
    # The boot-time `apply` will check again, but this catches a tampered
    # script at commit time so the operator sees the failure immediately
    # instead of on the next reboot (security-review v0.2.20 M1). Verify
    # the same script the active mode will run at boot.
    SCRIPT="$(pick_compiled)"
    [ -r "$SCRIPT" ] || { echo "[zfw] ERROR: compiled ruleset missing: $SCRIPT" >&2; exit 1; }
    secure_file "$SCRIPT" || exit 1
    # Dead-man teardown stays best-effort — the timer may simply not be
    # running on a host where commit is called outside an apply --safe
    # sequence, and that is fine.
    systemctl stop "${DEADMAN}.timer" 2>/dev/null || true
    systemctl reset-failed "${DEADMAN}.service" 2>/dev/null || true
    # CQ-10 (v1.0.2): every step that materially affects boot-persistence
    # is wrapped in apply_or_die so a silent failure no longer lets the
    # operator believe the commit succeeded. Pre-v1.0.2 only `enable`
    # was checked (R3-3); write_persist_unit and daemon-reload were
    # implicit-success.
    apply_or_die write_persist_unit
    apply_or_die systemctl daemon-reload
    # Surface enable failures (read-only /etc, masked unit, sysext
    # quirks). The redirect to /dev/null is dropped here so the
    # underlying systemctl error reaches the operator's terminal.
    apply_or_die systemctl enable zfw.service
    log "committed — deadman cancelled, boot-persistence enabled (zfw.service)"
    ;;
  revert)
    revert
    # Disable + remove the boot-restore unit so a fresh boot returns to the
    # stock state. daemon-reload after the rm so systemd forgets the unit.
    systemctl disable zfw.service >/dev/null 2>&1 || true
    rm -f "$PERSIST_UNIT" 2>/dev/null || true
    systemctl daemon-reload 2>/dev/null || true
    log "firewall reverted — all ZFW rules removed, stock state restored, boot-persistence disabled"
    ;;
  _autorevert)
    log "DEADMAN FIRED — reverting firewall"
    revert
    ;;
  status)
    echo "--- ZFW-IN ---";      $IPT -S ZFW-IN 2>/dev/null || echo "(not loaded)"
    echo "--- DOCKER-USER ---"; $IPT -S DOCKER-USER 2>/dev/null || echo "(absent)"
    echo "--- ZFW-OUT ---";     $IPT -S ZFW-OUT 2>/dev/null || echo "(not loaded — no outbound rules)"
    echo "--- ZFW-FWD-OUT ---"; $IPT -S ZFW-FWD-OUT 2>/dev/null || echo "(not loaded — no outbound docker rules)"
    [ -n "$IPT6" ] && { echo "--- ZFW-IN6 ---"; $IPT6 -S ZFW-IN6 2>/dev/null || echo "(not loaded)"; }
    [ -n "$IPT6" ] && { echo "--- ZFW-OUT6 ---"; $IPT6 -S ZFW-OUT6 2>/dev/null || echo "(not loaded)"; }
    echo "--- deadman ---";     systemctl is-active "${DEADMAN}.timer" 2>/dev/null || echo "inactive"
    ;;
  *)
    echo "usage: zfw {apply [--safe] | commit | revert | status}"
    exit 1
    ;;
esac
